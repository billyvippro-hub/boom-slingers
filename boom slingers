figma.ui.onmessage = (msg) => {
  if (msg.type === 'launch-sling') {
    let { vx, vy } = msg;
    
    const character = figma.createEllipse();
    character.name = "🚀_Boom_Slinger_Siêu_Cấp";
    character.resize(36, 36);
    
    // Lấy tọa độ hiện tại của góc màn hình sếp đang nhìn để thả bom cho chuẩn, không lo lệch map
    let posX = figma.viewport.center.x - 100;
    let posY = figma.viewport.center.y + 100;
    
    character.x = posX;
    character.y = posY;
    character.fills = [{ type: 'SOLID', color: { r: 0, g: 0.8, b: 1 } }]; // Màu xanh hi vọng không tự hủy

    const gravity = 0.55; 
    let tickCount = 0; // Bộ đếm thời gian bay bằng cơm
    
    // Vạch đất động = Vị trí xuất phát + 350px xuống dưới
    const groundLevel = posY + 350; 

    const engineLoop = setInterval(() => {
      posX += vx;
      posY += vy;
      vy += gravity; 

      character.x = posX;
      character.y = posY;
      tickCount++; // Tăng thời gian sống sót lên nào

      // ĐIỀU KIỆN KÍCH NỔ AN TOÀN: 
      // Phải bay được hơn 15 ticks (tầm 0.3 giây bảo hộ) THÌ mới xét điều kiện chạm đất!
      if (tickCount > 15 && (posY >= groundLevel || tickCount > 180)) {
        clearInterval(engineLoop);

        // Tạo vụ nổ bốc lửa cháy phố
        const boom = figma.createEllipse();
        boom.name = "💥_BÙM_CHÍU_CHÍU!!!";
        boom.resize(110, 110);
        boom.x = posX - 37;
        boom.y = posY - 37;
        boom.fills = [{ type: 'SOLID', color: { r: 1, g: 0.3, b: 0 } }];

        // Tiễn vong nhân vật cũ
        character.remove();
        
        figma.notify("Hạ cánh an toàn và nổ tung mục tiêu! 🎯");
      }
    }, 20); 
  }
