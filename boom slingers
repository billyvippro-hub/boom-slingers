<script>
  const canvas = document.getElementById('gameCanvas');
  const ctx = canvas.getContext('2d');
  const centerX = 140;
  const centerY = 160; // Dời bệ phóng xuống tí cho góc bắn rộng
  let slingX = centerX;
  let slingY = centerY;
  let isDragging = false;

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Vẽ background Grid Cyberpunk
    ctx.strokeStyle = '#1e1f29';
    ctx.lineWidth = 1;
    for(let i=0; i<canvas.width; i+=20) {
      ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvas.height); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(canvas.width, i); ctx.stroke();
    }

    // Nếu đang kéo gồng lực -> Vẽ đường dự đoán quỹ đạo (Trajectory Preview)
    if (isDragging) {
      ctx.beginPath();
      ctx.strokeStyle = '#00f5d4';
      ctx.lineWidth = 3;
      
      // Tính vector vận tốc giả lập
      const vx = (centerX - slingX) * 0.28;
      const vy = (centerY - slingY) * 0.28;
      
      // Chạy một vòng lặp ảo để vẽ trước đường cong Parabol
      let simX = centerX;
      let simY = centerY;
      let simVy = vy;
      const gravity = 0.55;

      ctx.beginPath();
      ctx.moveTo(simX, simY);
      
      for (let i = 0; i < 30; i++) { // Vẽ trước 30 bước đi của tương lai
        simX += vx;
        simY += simVy;
        simVy += gravity;
        
        // Vẽ nét đứt cho chanh sả
        if (i % 2 === 0) {
          ctx.lineTo(simX, simY);
        } else {
          ctx.moveTo(simX, simY);
        }
      }
      ctx.stroke();
    }

    // Vẽ bệ phóng súng cao su
    ctx.beginPath();
    ctx.arc(centerX, centerY, 6, 0, Math.PI * 2);
    ctx.fillStyle = '#ff007f';
    ctx.fill();

    // Vẽ dây thun co giãn khi kéo
    if (isDragging) {
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.4)';
      ctx.lineWidth = 4;
      ctx.moveTo(centerX, centerY);
      ctx.lineTo(slingX, slingY);
      ctx.stroke();
    }

    // Vẽ quả bom đỏ rực chuẩn bị phóng
    ctx.beginPath();
    ctx.arc(slingX, slingY, 12, 0, Math.PI * 2);
    ctx.fillStyle = isDragging ? '#00f5d4' : '#ff4757';
    ctx.fill();
    ctx.lineWidth = 2;
    ctx.strokeStyle = '#fff';
    ctx.stroke();
  }

  canvas.addEventListener('pointerdown', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mouseX = e.clientX - rect.left;
    const mouseY = e.clientY - rect.top;
    if (Math.hypot(mouseX - slingX, mouseY - slingY) < 25) {
      isDragging = true;
    }
  });

  canvas.addEventListener('pointermove', (e) => {
    if (!isDragging) return;
    const rect = canvas.getBoundingClientRect();
    let mouseX = e.clientX - rect.left;
    let mouseY = e.clientY - rect.top;

    // Giới hạn khoảng cách kéo tối đa 90px
    const dist = Math.hypot(mouseX - centerX, mouseY - centerY);
    if (dist > 90) {
      const angle = Math.atan2(mouseY - centerY, mouseX - centerX);
      mouseX = centerX + Math.cos(angle) * 90;
      mouseY = centerY + Math.sin(angle) * 90;
    }

    slingX = mouseX;
    slingY = mouseY;
    draw();
  });

  window.addEventListener('pointerup', () => {
    if (!isDragging) return;
    isDragging = false;

    const vx = (centerX - slingX) * 0.28; 
    const vy = (centerY - slingY) * 0.28;

    if (Math.hypot(vx, vy) > 1) {
      // Bắn thẳng sang Figma
      parent.postMessage({ pluginMessage: { type: 'super-launch', vx, vy } }, '*');
    }

    slingX = centerX;
    slingY = centerY;
    draw();
  });

  draw();
