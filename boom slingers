<script>
  const canvas = document.getElementById('gameCanvas');
  const ctx = canvas.getContext('2d');
  const centerX = 140;
  const centerY = 140;
  let slingX = centerX;
  let slingY = centerY;
  let isDragging = false;

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Vẽ lưới hack game
    ctx.strokeStyle = '#2a2b36';
    ctx.lineWidth = 1;
    for(let i=0; i<canvas.width; i+=20) {
      ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvas.height); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(canvas.width, i); ctx.stroke();
    }

    if (isDragging) {
      ctx.beginPath();
      ctx.strokeStyle = '#00f5d4'; // Đường ngắm laser xanh chanh sả
      ctx.lineWidth = 3;
      ctx.setLineDash([6, 4]);
      
      const targetX = centerX + (centerX - slingX);
      const targetY = centerY + (centerY - slingY);
      
      ctx.moveTo(centerX, centerY);
      ctx.lineTo(targetX, targetY);
      ctx.stroke();
      ctx.setLineDash([]);
    }

    ctx.beginPath();
    ctx.arc(centerX, centerY, 8, 0, Math.PI * 2);
    ctx.fillStyle = '#fff';
    ctx.fill();

    ctx.beginPath();
    ctx.arc(slingX, slingY, 14, 0, Math.PI * 2);
    ctx.fillStyle = '#ff4757';
    ctx.fill();
    ctx.lineWidth = 2;
    ctx.strokeStyle = '#fff';
    ctx.stroke();
  }

  canvas.addEventListener('pointerdown', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mouseX = e.clientX - rect.left;
    const mouseY = e.clientY - rect.top;
    if (Math.hypot(mouseX - slingX, mouseY - slingY) < 25) {
      isDragging = true;
    }
  });

  canvas.addEventListener('pointermove', (e) => {
    if (!isDragging) return;
    const rect = canvas.getBoundingClientRect();
    let mouseX = e.clientX - rect.left;
    let mouseY = e.clientY - rect.top;

    const dist = Math.hypot(mouseX - centerX, mouseY - centerY);
    if (dist > 80) {
      const angle = Math.atan2(mouseY - centerY, mouseX - centerX);
      mouseX = centerX + Math.cos(angle) * 80;
      mouseY = centerY + Math.sin(angle) * 80;
    }

    slingX = mouseX;
    slingY = mouseY;
    draw();
  });

  window.addEventListener('pointerup', () => {
    if (!isDragging) return;
    isDragging = false;

    // Tính lực phóng (Kéo càng căng, Vector phản lực càng mạnh)
    const vx = (centerX - slingX) * 0.28; 
    const vy = (centerY - slingY) * 0.28;

    if (Math.hypot(vx, vy) > 1) {
      parent.postMessage({ pluginMessage: { type: 'launch-sling', vx, vy } }, '*');
    }

    slingX = centerX;
    slingY = centerY;
    draw();
  });

  draw();
